<mujoco model="yam_blocks">
  <compiler angle="radian" meshdir="assets" texturedir="assets"/>
  <option integrator="implicitfast"/>

  <visual>
    <global azimuth="120" elevation="-20" offwidth="1920" offheight="1080"/>
    <quality shadowsize="8192" offsamples="16"/>
    <headlight ambient="0.40 0.40 0.40" diffuse="0.0 0.0 0.0" specular="0 0 0"/>
    <rgba haze="1.0 1.0 1.0 1"/>
  </visual>

  <default>
    <default class="yam">
      <position inheritrange="1"/>
      <joint frictionloss="0.1" axis="0 0 1"/>
      <default class="dm4340">
        <joint armature="0.032"/>
        <position kp="40" kv="2.5" forcerange="-28 28"/>
      </default>
      <default class="dm4310">
        <joint armature="0.0018"/>
        <position kp="10" kv="1" forcerange="-10 10"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" density="0" group="2" material="black"/>
      </default>
      <default class="collision">
        <geom group="3" type="capsule" friction="2.0 0.1 0.01" condim="6"/>
        <default class="sphere_collision">
          <geom size="0.0006 0 0" type="sphere" rgba="1 0 0 1" friction="4.0 0.1 0.01" condim="6" solimp="0.998 0.998 0.001" solref="0.004 1" priority="2"/>
        </default>
      </default>
      <default class="finger">
        <joint type="slide" armature="0.1" frictionloss="0.1"/>
        <position ctrlrange="0.0 0.0495" kp="400" kv="14" inheritrange="0"/>
      </default>
    </default>
    <default class="block">
      <geom type="mesh" contype="0" conaffinity="0" density="0" group="2"/>
    </default>
  </default>

